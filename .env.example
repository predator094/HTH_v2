# Storage (Cloudflare R2 or AWS S3 — both use boto3)
# For R2: fill R2_ACCOUNT_ID and R2_ENDPOINT_URL, leave STORAGE_REGION=auto
# For S3: leave R2_ACCOUNT_ID and R2_ENDPOINT_URL empty, set STORAGE_REGION to your bucket region
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=h2h-shares
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
STORAGE_REGION=auto

# Limits
MAX_UPLOAD_BYTES=104857600
MAX_STORAGE_BYTES=9663676416
MAX_EXPIRY_SECONDS=2592000
PENDING_UPLOAD_TIMEOUT=600
DOWNLOAD_URL_EXPIRY=900
UPLOAD_URL_EXPIRY=600
PASSCODE_MAX_ATTEMPTS=5
PASSCODE_LOCKOUT_SECONDS=300

# Rate limiting
RATE_LIMIT_UPLOAD=10/hour
RATE_LIMIT_CONFIRM=20/hour
RATE_LIMIT_READ=30/minute
RATE_LIMIT_DELETE=10/hour

# DB (Neon PostgreSQL — use the pooled connection string from the Neon dashboard)
DATABASE_URL=postgresql://user:pass@ep-xxx-yyy.region.aws.neon.tech/neondb?sslmode=require

# App
FRONTEND_ORIGIN=https://h2h.pred8ar.in
